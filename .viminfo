	    # 앞쪽 빈칸들을 학생 데이터 폭(6칸씩 6번 = 36칸)만큼 밀고, 마지막 %6s 자리에 평균을 넣습니다.
	    printf "%36s %6s\n", "국어평균", kor_avg
	    printf "%36s %6s\n", "영어평균", eng_avg
	    printf "%36s %6s\n", "수학평균", math_avg
	}
|3,0,9,1,28,0,1780885838,"NR == 1 {","    printf \"%6s %6s %6s %6s %6s %6s %6s\\n\", $1, $2, $3, $4, $5, \"총점\", \"평균\"","    next","}","","NR > 1 {","    sum = $3 + $4 + $5","    avg_str = sprintf(\"%.1f\", sum / 3)","    ","    printf \"%6s %6s %6d %6d %6d %6d %6s\\n\", $1, $2, $3, $4, $5, sum, avg_str","    ","    kor_total += $3","    eng_total += $4","    math_total += $5","    count++","}","","END {",>50
|<"    kor_avg = sprintf(\"%.1f\", kor_total/count)","    eng_avg = sprintf(\"%.1f\", eng_total/count)","    math_avg = sprintf(\"%.1f\", math_total/count)","","    printf \"\\n\"","    # 앞쪽 빈칸들을 학생 데이터 폭(6칸씩 6번 = 36칸)만큼 밀고, 마지막 %6s 자리에 평균을 넣습니다.","    printf \"%36s %6s\\n\", \"국어평균\", kor_avg","    printf \"%36s %6s\\n\", \"영어평균\", eng_avg","    printf \"%36s %6s\\n\", \"수학평균\", math_avg","}"
