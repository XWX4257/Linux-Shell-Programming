|3,0,0,1,1,0,1775070521,"May I sit here?"
""1	LINE	0
	NR == 1 {
	    subject_count = NF - 2
	    for (i = 1; i <= NF; i++) {
	        header[i] = $i
	    }
	    printf "%-8s %-8s", header[1], header[2]
	    for (i = 3; i <= NF; i++) {
	        printf " %-8s", header[i]
	    }
	    printf " %-8s %-8s\n", "총점", "평균"
	    next
	}
	
	NR > 1 {
	    sum = 0
	    printf "%-8s %-8s", $1, $2
	    for (i = 3; i <= NF; i++) {
	        printf " %-8d", $i
	        sum += $i
	        subj_total[i] += $i
	    }
	    avg_str = sprintf("%.1f", sum / subject_count)
	    printf " %-8d %-8s\n", sum, avg_str
	    count++
	}
	
	END {
	    printf "\n"
	    printf "%-8s %-8s", "", ""
	    for (i = 3; i <= subject_count + 2; i++) {
	        subj_avg = sprintf("%.1f", subj_total[i] / count)
	        printf " %-8s", subj_avg
	    }
	    printf "\n"
	}
