"4	LINE	0
	NR == 1 {
	    printf "%6s %6s %6s %6s %6s %6s %6s\n", $1, $2, $3, $4, $5, "총점", "평균"
	    next
	}
	
	NR > 1 {
	    sum = $3 + $4 + $5
	    avg = sum / 3
	    avg_str = sprintf("%.1f", avg)
	    
	    printf "%6s %6s %6d %6d %6d %6d %6s\n", $1, $2, $3, $4, $5, sum, avg_str
	    
	    kor_total += $3
	    eng_total += $4
	    math_total += $5
	    sum_total += sum
	    avg_total += avg
	    count++
	}
	
	END {
	    kor_avg = sprintf("%.1f", kor_total/count)
	    eng_avg = sprintf("%.1f", eng_total/count)
	    math_avg = sprintf("%.1f", math_total/count)
	    sum_avg = sprintf("%.1f", sum_total/count)
	    all_avg = sprintf("%.1f", avg_total/count)
	
	    printf "\n"
	    # 앞의 학번, 이름 자리는 빈 문자열("")로 비워두고
	    # 국어, 영어, 수학, 총점, 평균 자리에 똑같이 %6s 규격을 적용해 수직으로 맞춥니다.
	    printf "%6s %6s %6s %6s %6s %6s %6s\n", "", "", kor_avg, eng_avg, math_avg, sum_avg, all_avg
	}
